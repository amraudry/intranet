# =============================================================
# INTRANET ARQ — Variables de entorno
# Copiar este archivo como .env y completar los valores
# NUNCA subir .env al repositorio (está en .gitignore)
# =============================================================

# Servidor
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5500

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=dev
DB_PASSWORD=Dev1234
DB_NAME=intranet_arq

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio_min_64_chars
JWT_EXPIRES_IN=8h

# SSO Microsoft Azure AD
MICROSOFT_TENANT_ID=YOUR_TENANT_ID
MICROSOFT_CLIENT_ID=YOUR_CLIENT_ID
MICROSOFT_CLIENT_SECRET=YOUR_CLIENT_SECRET
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Almacenamiento de archivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Seguridad
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
