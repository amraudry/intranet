<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Intranet Arq | Acceso Seguro</title>
  
  <!-- Security Headers via Meta Tags -->
  <meta http-equiv="Content-Security-Policy" 
        content="default-src 'self'; script-src 'self' https://unpkg.com; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https://picsum.photos; connect-src 'self' https://login.microsoftonline.com;">
  <meta http-equiv="X-Content-Type-Options" content="nosniff">
  <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin">
  <meta name="robots" content="noindex, nofollow">
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Barlow+Condensed:wght@400;500;600&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
  
  <!-- Styles -->
  <link rel="stylesheet" href="css/main.css">
  <link rel="stylesheet" href="css/auth.css">
</head>
<body class="auth-page">
  
  <!-- Patrón de fondo tipo plano arquitectónico -->
  <div class="blueprint-bg" aria-hidden="true"></div>
  
  <!-- Contenedor principal de login -->
  <main class="auth-container" role="main">
    
    <!-- Panel izquierdo: Branding y cita inspiradora -->
    <aside class="auth-branding" aria-label="Información institucional">
      <div class="brand-content">
        <div class="brand-logo">
          <i data-lucide="building-2" class="logo-icon" aria-hidden="true"></i>
          <span class="brand-name">ARQ<span class="brand-accent">CORP</span></span>
        </div>
        <blockquote class="brand-quote">
          "La arquitectura es el juego sabio, correcto y magnífico de los volúmenes bajo la luz."
          <cite>— Le Corbusier</cite>
        </blockquote>
        <div class="brand-watermark" aria-hidden="true">
          <span class="section-number">§ 01</span>
          <span class="section-title">ACCESO</span>
        </div>
      </div>
    </aside>
    
    <!-- Panel derecho: Formulario de autenticación -->
    <section class="auth-form-panel" aria-label="Formulario de acceso">
      <div class="auth-form-wrapper">
        
        <header class="auth-header">
          <h1 class="auth-title">Intranet Corporativa</h1>
          <p class="auth-subtitle">Gestión Documental • Arquitectura & Construcción</p>
        </header>
        
        <!-- Formulario de login local -->
        <form id="loginForm" class="auth-form" novalidate autocomplete="on">
          
          <!-- Token CSRF (simulado) -->
          <input type="hidden" id="csrfToken" name="csrfToken">
          
          <div class="form-group">
            <label for="email" class="form-label">
              <i data-lucide="mail" class="label-icon" aria-hidden="true"></i>
              Correo Electrónico
            </label>
            <input 
              type="email" 
              id="email" 
              name="email"
              class="form-input" 
              placeholder="usuario@empresa.com"
              required
              autocomplete="username"
              pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$"
              aria-describedby="emailError"
            >
            <span id="emailError" class="form-error" role="alert" aria-live="polite"></span>
          </div>
          
          <div class="form-group">
            <label for="password" class="form-label">
              <i data-lucide="lock" class="label-icon" aria-hidden="true"></i>
              Contraseña
            </label>
            <div class="password-wrapper">
              <input 
                type="password" 
                id="password" 
                name="password"
                class="form-input" 
                placeholder="••••••••"
                required
                minlength="8"
                autocomplete="current-password"
                aria-describedby="passwordError"
              >
              <button type="button" class="password-toggle" aria-label="Mostrar/ocultar contraseña">
                <i data-lucide="eye" class="toggle-icon eye-open" aria-hidden="true"></i>
                <i data-lucide="eye-off" class="toggle-icon eye-closed" aria-hidden="true"></i>
              </button>
            </div>
            <span id="passwordError" class="form-error" role="alert" aria-live="polite"></span>
          </div>
          
          <!-- Mensaje de rate limiting -->
          <div id="rateLimitMessage" class="rate-limit-warning" hidden role="alert">
            <i data-lucide="alert-circle" aria-hidden="true"></i>
            <span id="rateLimitTimer">Demasiados intentos. Espera <span id="secondsLeft">30</span>s para reintentar.</span>
          </div>
          
          <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-block" id="submitBtn">
              <i data-lucide="log-in" aria-hidden="true"></i>
              Ingresar
            </button>
            
            <!-- Separador -->
            <div class="auth-divider">
              <span class="divider-line"></span>
              <span class="divider-text">o continuar con</span>
              <span class="divider-line"></span>
            </div>
            
            <!-- Botón SSO Microsoft -->
            <button type="button" class="btn btn-secondary btn-block btn-sso" id="ssoBtn">
              <svg class="sso-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="#F25022" d="M1 1h10v10H1z"/>
                <path fill="#7FBA00" d="M13 1h10v10H13z"/>
                <path fill="#00A4EF" d="M1 13h10v10H1z"/>
                <path fill="#FFB900" d="M13 13h10v10H13z"/>
              </svg>
              Continuar con Office
            </button>
          </div>
          
          <div class="form-footer">
            <a href="#" class="forgot-link" id="forgotPassword">¿Olvidaste tu contraseña?</a>
          </div>
          
        </form>
        
        <!-- Mensajes de estado -->
        <div id="authMessage" class="auth-message" role="status" aria-live="polite" hidden></div>
        
      </div>
    </section>
    
  </main>
  
  <!-- Scripts -->
  <script src="js/security.js"></script>
  <script src="js/session.js"></script>
  <script src="js/auth.js"></script>
  
  <script>
    // Inicializar iconos Lucide
    lucide.createIcons();
  </script>
</body>
</html>